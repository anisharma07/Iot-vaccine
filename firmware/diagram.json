{
  "version": 1,
  "author": "Smart Vaccine Delivery System",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-dht22",
      "id": "dht1",
      "top": -120,
      "left": -180,
      "attrs": {
        "temperature": "5",
        "humidity": "45"
      }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot_accelX",
      "top": -120,
      "left": 200,
      "attrs": {
        "value": "50"
      }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot_accelY",
      "top": -20,
      "left": 200,
      "attrs": {
        "value": "50"
      }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot_gas",
      "top": 80,
      "left": 200,
      "attrs": {
        "value": "10"
      }
    },
    {
      "type": "wokwi-pushbutton",
      "id": "btn_tamper",
      "top": 180,
      "left": -180,
      "attrs": {
        "color": "red",
        "label": "TAMPER"
      }
    },
    {
      "type": "wokwi-buzzer",
      "id": "buzzer1",
      "top": 180,
      "left": -60,
      "attrs": {}
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 180,
      "left": 60,
      "attrs": {
        "color": "red"
      }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": -60,
      "left": -120,
      "attrs": {
        "value": "4700"
      }
    },
    {
      "type": "wokwi-resistor",
      "id": "r2",
      "top": 180,
      "left": 120,
      "attrs": {
        "value": "220"
      }
    }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["dht1:VCC", "esp:3V3", "red", ["v0"]],
    ["dht1:GND", "esp:GND.2", "black", ["v0"]],
    ["dht1:SDA", "esp:4", "green", ["v0"]],
    ["dht1:SDA", "r1:1", "green", ["v0"]],
    ["r1:2", "esp:3V3", "red", ["v0"]],

    ["pot_accelX:VCC", "esp:3V3", "red", ["v0"]],
    ["pot_accelX:GND", "esp:GND.1", "black", ["v0"]],
    ["pot_accelX:SIG", "esp:35", "orange", ["v0"]],

    ["pot_accelY:VCC", "esp:3V3", "red", ["v0"]],
    ["pot_accelY:GND", "esp:GND.1", "black", ["v0"]],
    ["pot_accelY:SIG", "esp:32", "yellow", ["v0"]],

    ["pot_gas:VCC", "esp:3V3", "red", ["v0"]],
    ["pot_gas:GND", "esp:GND.1", "black", ["v0"]],
    ["pot_gas:SIG", "esp:34", "purple", ["v0"]],

    ["btn_tamper:1.l", "esp:15", "blue", ["v0"]],
    ["btn_tamper:2.l", "esp:GND.2", "black", ["v0"]],

    ["buzzer1:1", "esp:13", "brown", ["v0"]],
    ["buzzer1:2", "esp:GND.2", "black", ["v0"]],

    ["led1:A", "r2:1", "red", ["v0"]],
    ["r2:2", "esp:2", "red", ["v0"]],
    ["led1:C", "esp:GND.2", "black", ["v0"]]
  ],
  "serialMonitor": {
    "display": "auto",
    "newline": "lf"
  }
}
